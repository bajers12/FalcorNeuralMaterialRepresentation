float2 mx_transform_uv(float2 uv, float2 uv_scale, float2 uv_offset)
{
    uv = uv * uv_scale + uv_offset;
    return uv;
}

void mx_image_vector3(SamplerTexture2D tex_sampler, int layer, float3 defaultval, float2 texcoord, int uaddressmode, int vaddressmode, int filtertype, int framerange, int frameoffset, int frameendaction, float2 uv_scale, float2 uv_offset, out float3 result)
{
    float2 uv = mx_transform_uv(texcoord, uv_scale, uv_offset);
    result = texture(tex_sampler, uv).rgb;
}

void mx_normalmap_vector2(float3 value, float2 normal_scale, float3 N, float3 T, float3 B, out float3 result)
{
    value = (dot(value, value) == 0.0) ? float3(0.0, 0.0, 1.0) : value * 2.0 - 1.0;
    value = T * value.x * normal_scale.x +
            B * value.y * normal_scale.y +
            N * value.z;
    result = normalize(value);
}

void mx_normalmap_float(float3 value, float normal_scale, float3 N, float3 T, float3 B, out float3 result)
{
    mx_normalmap_vector2(value, float2(normal_scale), N, T, B, result);
}
float4 call_normal_output(VertexData _vd)
{
    // Fragment shader inputs
    vd = _vd;
    // Pixel shader outputs
    float4 normal_output;

    float2 node_texcoord_vector2_9_out = vd.texcoord_0.xy;
    float3 geomprop_Nworld_out1 = normalize(vd.normalWorld);
    float3 geomprop_Tworld_out1 = normalize(vd.tangentWorld);
    float3 geomprop_Bworld_out1 = normalize(vd.bitangentWorld);
    float2 node_multiply_10_out = node_texcoord_vector2_9_out * g_mtlx_normal_param_node_multiply_10_in2;
    float3 node_image_vector3_11_out = float3(0.0);
    mx_image_vector3(node_image_vector3_11_file, g_mtlx_normal_param_node_image_vector3_11_layer, g_mtlx_normal_param_node_image_vector3_11_default, node_multiply_10_out, g_mtlx_normal_param_node_image_vector3_11_uaddressmode, g_mtlx_normal_param_node_image_vector3_11_vaddressmode, g_mtlx_normal_param_node_image_vector3_11_filtertype, g_mtlx_normal_param_node_image_vector3_11_framerange, g_mtlx_normal_param_node_image_vector3_11_frameoffset, g_mtlx_normal_param_node_image_vector3_11_frameendaction, g_mtlx_normal_param_node_image_vector3_11_uv_scale, g_mtlx_normal_param_node_image_vector3_11_uv_offset, node_image_vector3_11_out);
    float3 node_normalmap_out = float3(0.0);
    mx_normalmap_float(node_image_vector3_11_out, g_mtlx_normal_param_node_normalmap_scale, geomprop_Nworld_out1, geomprop_Tworld_out1, geomprop_Bworld_out1, node_normalmap_out);
    normal_output = float4(node_normalmap_out, 1.0);
    return normal_output;
}

