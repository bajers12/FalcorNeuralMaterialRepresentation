MtlxSurfaceParams evalMaterialXSurface(MtlxEvalContext ctx)
{
    MtlxSurfaceParams r = {};
    r.baseWeight = 0.800000012;
    r.baseColor = float3(0.18, 0.18, 0.18);
    r.metallic = 0.0;
    r.roughness = 0.5;
    r.specularWeight = 1.0;
    r.specularColor = float3(1.0, 1.0, 1.0);
    r.normalTS = float3(0.0, 0.0, 1.0);
    r.hasNormal = false;
    r.normalWS = ctx.normalWS;
    r.hasNormalWS = false;
    r.tangentWS = ctx.tangentWS;
    r.hasTangent = false;
    r.emission = (float3(1.0, 1.0, 1.0)) * (0.0);
    r.opacity = 1.0;
    r.transmissionColor = (float3(1.0, 1.0, 1.0)) * (0.0);
    r.specularTransmission = 0.0;
    r.ior = 1.5;
    r.coatWeight = 0.0;
    r.coatColor = float3(1.0, 1.0, 1.0);
    r.coatRoughness = 0.100000001;
    r.coatIor = 1.5;
    r.coatAffectColor = 0.0;
    r.coatAffectRoughness = 0.0;
    r.coatNormalTS = float3(0.0, 0.0, 1.0);
    r.hasCoatNormal = false;
    r.sheenWeight = 0.0;
    r.sheenColor = float3(1.0, 1.0, 1.0);
    r.sheenRoughness = 0.300000012;

    r.baseColor = mxExtractRgb(eval_output_base_color_output(ctx));
    r.metallic = mxExtractScalar(eval_output_metalness_output(ctx));
    r.roughness = mxExtractScalar(eval_output_specular_roughness_output(ctx));
    r.normalWS = mxSafeNormalize3(mxExtractRgb(eval_output_normal_output(ctx)), ctx.normalWS);
    r.hasNormalWS = true;
    r.tangentWS = mxSafeNormalize3(mxExtractRgb(eval_output_tangent_output(ctx)), ctx.tangentWS);
    r.hasTangent = true;

    return r;
}

struct NG_Blue_Mosaic_Tiles_with_Gold_GeneratedMtlxMaterial : MaterialBase, IMaterial
{
    MaterialXGeneratedPayloadData data;
    typedef StandardMaterialInstance MaterialInstance;

    StandardMaterialInstance setupMaterialInstance(const MaterialSystem ms, const ShadingData sd, const ITextureSampler lod, const uint hints = (uint)MaterialInstanceHints::None)
    {
        MtlxEvalContext ctx = {};
        ctx.uv0 = sd.uv;
        ctx.positionWS = sd.posW;
        ctx.normalWS = mxSafeNormalize3(sd.frame.N, float3(0.0, 0.0, 1.0));
        ctx.tangentWS = mxMakeOrthogonalTangent(ctx.normalWS, sd.tangentW.xyz);
        ctx.bitangentWS = mxSafeNormalize3(cross(ctx.normalWS, ctx.tangentWS), cross(ctx.normalWS, mxFallbackTangent(ctx.normalWS))) * sd.tangentW.w;
        ctx.color0 = float4(1.0);
        ctx.color1 = float4(1.0);
        ctx.color2 = float4(1.0);
        ctx.color3 = float4(1.0);
        ctx.V = sd.V;
        ctx.frontFacing = sd.frontFacing;

        MtlxSurfaceParams p = evalMaterialXSurface(ctx);

        StandardBSDFData d = {};
        float ior = max(p.ior, 1.001f);
        d.eta = sd.frontFacing ? (sd.IoR / ior) : (ior / sd.IoR);

        float f = (ior - 1.f) / (ior + 1.f);
        float dielectricF0 = f * f;

        float metallic = saturate(p.metallic);
        float roughness = clamp(p.roughness, 1e-3f, 1.f);
        float baseWeight = saturate(p.baseWeight);
        float specularWeight = saturate(p.specularWeight);
        float3 baseColor = saturate(p.baseColor);
        float3 specularColor = saturate(p.specularColor);
        float coatWeight = saturate(p.coatWeight);
        float coatRoughness = clamp(max(p.coatRoughness, 0.0f), 1e-3f, 1.f);
        float coatIor = max(p.coatIor, 1.001f);
        float coatAffectColor = saturate(p.coatAffectColor);
        float coatAffectRoughness = saturate(p.coatAffectRoughness);
        float sheenWeight = saturate(p.sheenWeight) * saturate(1.f - metallic);
        float sheenRoughness = clamp(max(p.sheenRoughness, 0.0f), 1e-3f, 1.f);
        float3 sheenColor = saturate(p.sheenColor);

        float3 dielectricSpec = float3(dielectricF0) * specularWeight * specularColor;
        float glazeStrength = saturate((1.f - metallic) * specularWeight * baseWeight);
        float glazeRoughness = clamp(lerp(0.015f, 0.18f, sqrt(saturate(roughness))), 1e-3f, 1.f);
        float baseLayerRoughness = clamp(max(roughness, 0.02f), 1e-3f, 1.f);
        d.diffuse = baseWeight * lerp(baseColor, float3(0.f), metallic);
        d.specular = lerp(dielectricSpec, baseColor, metallic);
        d.roughness = baseLayerRoughness;
        if (glazeStrength > 0.f)
        {
            float glazeMix = saturate(glazeStrength * (0.35f + 0.65f * saturate(1.f - roughness)));
            float3 glazeSpec = dielectricSpec * lerp(1.0.xxx, 1.35.xxx, saturate(1.f - roughness));
            d.diffuse *= lerp(1.0.xxx, 0.92.xxx, glazeMix);
            d.specular = lerp(d.specular, max(d.specular, glazeSpec), glazeMix);
            d.roughness = lerp(d.roughness, min(d.roughness, glazeRoughness), glazeMix);
        }
        if (sheenWeight > 0.f)
        {
            float3 sheenTint = lerp(float3(1.f), sheenColor, 0.5f);
            float3 sheenSpec = 0.04f * sheenTint;
            d.diffuse *= lerp(float3(1.f), sheenTint, 0.15f * sheenWeight);
            d.specular = max(d.specular, sheenSpec * sheenWeight);
            d.roughness = lerp(d.roughness, max(d.roughness, sheenRoughness), 0.35f * sheenWeight);
        }
        if (coatWeight > 0.f)
        {
            float cf = (coatIor - 1.f) / (coatIor + 1.f);
            float coatF0 = cf * cf;
            float3 coatColor = saturate(p.coatColor);
            float3 coatSpec = float3(coatF0) * coatColor;
            float3 belowColor = lerp(float3(1.f), coatColor, coatAffectColor * coatWeight);
            float roughnessUnderCoat = lerp(d.roughness, max(d.roughness, coatRoughness), coatAffectRoughness * coatWeight);
            d.diffuse *= belowColor;
            d.specular *= belowColor;
            d.specular = lerp(d.specular, max(d.specular, coatSpec), coatWeight);
            d.roughness = lerp(roughnessUnderCoat, min(roughnessUnderCoat, coatRoughness), coatWeight);
        }
        d.metallic = metallic;
        d.transmission = saturate(p.transmissionColor);
        d.diffuseTransmission = 0.f;
        d.specularTransmission = saturate(p.specularTransmission);
        d.volumeScattering = float3(0.f);
        d.volumeAnsiotropy = 0.f;
        d.hasEntryPointVolumeProperties = false;
        d.hasSigmaSGreaterZero = false;

        ShadingFrame sf = sd.frame;
        if (p.hasNormalWS)
        {
            float3 N = mxSafeNormalize3(p.normalWS, sf.N);
            float3 T = mxMakeOrthogonalTangent(N, p.hasTangent ? p.tangentWS : sd.tangentW.xyz);
            sf = ShadingFrame(N, float4(T, sd.tangentW.w));
        }
        else if (isNormalMappingEnabled(hints) && p.hasNormal)
        {
            float3 T = mxMakeOrthogonalTangent(sf.N, p.hasTangent ? p.tangentWS : sd.tangentW.xyz);
            float3 B = mxSafeNormalize3(cross(sf.N, T), cross(sf.N, mxFallbackTangent(sf.N))) * sd.tangentW.w;
            float3 nTS = mxSafeNormalize3(p.normalTS, float3(0.0, 0.0, 1.0));
            float3 N = mxSafeNormalize3(nTS.x * T + nTS.y * B + nTS.z * sf.N, sf.N);
            T = mxMakeOrthogonalTangent(N, T);
            sf = ShadingFrame(N, float4(T, sd.tangentW.w));
        }
        flipShadingNormal(sd, sf);
        if (isAdjustShadingNormalEnabled(hints))
        {
            adjustShadingNormal(sd, sf);
        }

        float3 emission = sd.frontFacing ? p.emission : float3(0.f);
        return StandardMaterialInstance(sf, d, emission);
    }

    [Differentiable] StandardMaterialInstance setupDiffMaterialInstance(out DiffMaterialData diffData, const MaterialSystem ms, const ShadingData sd, const ITextureSampler lod, const uint hints = (uint)MaterialInstanceHints::None)
    {
        diffData = {};
        return no_diff setupMaterialInstance(ms, sd, lod, hints);
    }
};

// Notes:
// - Ambient occlusion outputs are intentionally omitted.
// - The generated Falcor module uses StandardMaterialInstance as its BSDF implementation.
// - Exact MaterialX coat/sheen layering is not represented in Falcor's StandardBSDFData and is therefore approximate.
// - Per-hit alpha cutout integration is not generated here; opacity is exposed and the manifest alphaMode is set for host-side handling.

#endif // MTLX_NG_BLUE_MOSAIC_TILES_WITH_GOLD_FALCOR_GENERATED
