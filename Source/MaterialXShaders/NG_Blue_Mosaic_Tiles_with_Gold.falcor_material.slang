float2 mx_transform_uv(float2 uv, float2 uv_scale, float2 uv_offset)
{
    uv = uv * uv_scale + uv_offset;
    return uv;
}

void mx_image_vector3(SamplerTexture2D tex_sampler, int layer, float3 defaultval, float2 texcoord, int uaddressmode, int vaddressmode, int filtertype, int framerange, int frameoffset, int frameendaction, float2 uv_scale, float2 uv_offset, out float3 result)
{
    float2 uv = mx_transform_uv(texcoord, uv_scale, uv_offset);
    result = texture(tex_sampler, uv).rgb;
}
float4 call_specular_roughness_output(VertexData _vd)
{
    // Fragment shader inputs
    vd = _vd;
    // Pixel shader outputs
    float4 specular_roughness_output;

    float2 node_texcoord_vector2_9_out = vd.texcoord_0.xy;
    float2 node_multiply_10_out = node_texcoord_vector2_9_out * node_multiply_10_in2;
    float3 node_image_vector3_13_out = float3(0.0);
    mx_image_vector3(node_image_vector3_13_file, node_image_vector3_13_layer, node_image_vector3_13_default, node_multiply_10_out, node_image_vector3_13_uaddressmode, node_image_vector3_13_vaddressmode, node_image_vector3_13_filtertype, node_image_vector3_13_framerange, node_image_vector3_13_frameoffset, node_image_vector3_13_frameendaction, node_image_vector3_13_uv_scale, node_image_vector3_13_uv_offset, node_image_vector3_13_out);
    float node_extract_12_out = node_image_vector3_13_out[node_extract_12_index];
    float node_mix_4_out = lerp(node_mix_4_bg, node_mix_4_fg, node_extract_12_out);
    specular_roughness_output = float4(node_mix_4_out, node_mix_4_out, node_mix_4_out, 1.0);
    return specular_roughness_output;
}

