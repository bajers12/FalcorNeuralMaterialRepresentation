    return vd;
}

MtlxOut_tangent_output::VertexData build_MtlxOut_tangent_output_vertex_data(MtlxEvalContext ctx)
{
    MtlxOut_tangent_output::VertexData vd = {};
    vd.SV_Position = float4(ctx.positionWS, 1.0);
    vd.tangentWorld = ctx.tangentWS;
    return vd;
}

float4 eval_baseColor(MtlxEvalContext ctx)
{
    return MtlxOut_base_color_output::call_base_color_output(build_MtlxOut_base_color_output_vertex_data(ctx));
}

float4 eval_coatNormal(MtlxEvalContext ctx)
{
    return MtlxOut_coat_normal_output::call_coat_normal_output(build_MtlxOut_coat_normal_output_vertex_data(ctx));
}

float4 eval_metallic(MtlxEvalContext ctx)
{
    return MtlxOut_metalness_output::call_metalness_output(build_MtlxOut_metalness_output_vertex_data(ctx));
}

float4 eval_normal(MtlxEvalContext ctx)
{
    return MtlxOut_normal_output::call_normal_output(build_MtlxOut_normal_output_vertex_data(ctx));
}

float4 eval_roughness(MtlxEvalContext ctx)
{
    return MtlxOut_specular_roughness_output::call_specular_roughness_output(build_MtlxOut_specular_roughness_output_vertex_data(ctx));
}

float4 eval_tangent(MtlxEvalContext ctx)
{
    return MtlxOut_tangent_output::call_tangent_output(build_MtlxOut_tangent_output_vertex_data(ctx));
}

MtlxSurfaceParams evalMaterialXSurface(MtlxEvalContext ctx)
{
    MtlxSurfaceParams r = {};
    r.baseColor = float3(0.18, 0.18, 0.18);
    r.metallic = 0.0;
    r.roughness = 0.5;
    r.normalTS = float3(0.0, 0.0, 1.0);
    r.hasNormal = false;
    r.tangentWS = ctx.tangentWS;
    r.hasTangent = false;
    r.emission = float3(0.0, 0.0, 0.0);
    r.opacity = 1.0;
    r.transmissionColor = float3(0.0, 0.0, 0.0);
    r.specularTransmission = 0.0;
    r.ior = 1.5;
    r.coatWeight = 0.0;
    r.coatRoughness = 0.0;
    r.coatNormalTS = float3(0.0, 0.0, 1.0);
    r.hasCoatNormal = false;

    r.baseColor = mxExtractRgb(eval_baseColor(ctx));
    r.metallic = mxExtractScalar(eval_metallic(ctx));
    r.roughness = mxExtractScalar(eval_roughness(ctx));
    r.normalTS = normalize(mxExtractRgb(eval_normal(ctx)));
    r.hasNormal = true;
    r.tangentWS = normalize(mxExtractRgb(eval_tangent(ctx)));
    r.hasTangent = true;
    r.coatNormalTS = normalize(mxExtractRgb(eval_coatNormal(ctx)));
    r.hasCoatNormal = true;

    return r;
}

struct NG_Blue_Mosaic_Tiles_with_Gold_GeneratedMtlxMaterial : MaterialBase, IMaterial
{
    MaterialXGeneratedPayloadData data;
    typedef StandardMaterialInstance MaterialInstance;

    StandardMaterialInstance setupMaterialInstance(const MaterialSystem ms, const ShadingData sd, const ITextureSampler lod, const uint hints = (uint)MaterialInstanceHints::None)
    {
        MtlxEvalContext ctx = {};
        ctx.uv0 = sd.uv;
        ctx.positionWS = sd.posW;
        ctx.normalWS = sd.frame.N;
        ctx.tangentWS = normalize(sd.tangentW.xyz);
        ctx.bitangentWS = normalize(cross(ctx.normalWS, ctx.tangentWS)) * sd.tangentW.w;
        ctx.color0 = float4(1.0);
        ctx.color1 = float4(1.0);
        ctx.color2 = float4(1.0);
        ctx.color3 = float4(1.0);
        ctx.V = sd.V;
        ctx.frontFacing = sd.frontFacing;

        MtlxSurfaceParams p = evalMaterialXSurface(ctx);

        StandardBSDFData d = {};
        float ior = max(p.ior, 1.001f);
        d.eta = sd.frontFacing ? (sd.IoR / ior) : (ior / sd.IoR);

        float f = (ior - 1.f) / (ior + 1.f);
        float dielectricF0 = f * f;

        float metallic = saturate(p.metallic);
        float roughness = clamp(p.roughness, 1e-3f, 1.f);
        float3 baseColor = saturate(p.baseColor);

        d.diffuse = lerp(baseColor, float3(0.f), metallic);
        d.specular = lerp(float3(dielectricF0), baseColor, metallic);
        d.roughness = roughness;
        d.metallic = metallic;
        d.transmission = saturate(p.transmissionColor);
        d.diffuseTransmission = 0.f;
        d.specularTransmission = saturate(p.specularTransmission);
        d.volumeScattering = float3(0.f);
        d.volumeAnsiotropy = 0.f;
        d.hasEntryPointVolumeProperties = false;
        d.hasSigmaSGreaterZero = false;

        ShadingFrame sf = sd.frame;
        if (isNormalMappingEnabled(hints) && p.hasNormal)
        {
            float3 T = normalize(p.hasTangent ? p.tangentWS : sd.tangentW.xyz);
            float3 B = normalize(cross(sf.N, T)) * sd.tangentW.w;
            float3 N = normalize(p.normalTS.x * T + p.normalTS.y * B + p.normalTS.z * sf.N);
            sf = ShadingFrame(N, float4(T, sd.tangentW.w));
        }
        flipShadingNormal(sd, sf);
        if (isAdjustShadingNormalEnabled(hints))
        {
            adjustShadingNormal(sd, sf);
        }

        float3 emission = sd.frontFacing ? p.emission : float3(0.f);
        return StandardMaterialInstance(sf, d, emission);
    }

    [Differentiable] StandardMaterialInstance setupDiffMaterialInstance(out DiffMaterialData diffData, const MaterialSystem ms, const ShadingData sd, const ITextureSampler lod, const uint hints = (uint)MaterialInstanceHints::None)
    {
        diffData = {};
        return no_diff setupMaterialInstance(ms, sd, lod, hints);
    }
};

// Notes:
// - Ambient occlusion outputs are intentionally omitted.
// - The generated Falcor module uses StandardMaterialInstance as its BSDF implementation.
// - Exact MaterialX coat/sheen layering is not represented in Falcor's StandardBSDFData and is therefore approximate.
// - Per-hit alpha cutout integration is not generated here; opacity is exposed and the manifest alphaMode is set for host-side handling.

#endif // MTLX_NG_BLUE_MOSAIC_TILES_WITH_GOLD_FALCOR_GENERATED
